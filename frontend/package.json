{
  "name": "graphlagoon-frontend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc && vite build",
    "preview": "vite preview",
    "test": "vitest",
    "test:run": "vitest run",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint . --ext .vue,.js,.jsx,.cjs,.mjs,.ts,.tsx,.cts,.mts --fix",
    "e2e": "playwright test --config e2e/playwright.config.ts",
    "e2e:ui": "playwright test --config e2e/playwright.config.ts --ui",
    "e2e:report": "playwright show-report playwright-report",
    "e2e:headed": "playwright test --config e2e/playwright.config.ts --headed",
    "e2e:integration": "playwright test --config e2e/playwright.integration.config.ts",
    "e2e:integration:headed": "playwright test --config e2e/playwright.integration.config.ts --headed",
    "screenshots": "playwright test --config e2e/screenshots/playwright.screenshots.config.ts",
    "perf-report": "tsx e2e/perf-report.ts"
  },
  "dependencies": {
    "@codemirror/autocomplete": "^6.20.0",
    "@codemirror/lang-javascript": "^6.2.4",
    "@codemirror/lang-sql": "^6.10.0",
    "@codemirror/language": "^6.12.1",
    "@codemirror/state": "^6.5.4",
    "@codemirror/view": "^6.39.12",
    "@primevue/themes": "^4.5.4",
    "@tanstack/vue-table": "^8.21.3",
    "@tanstack/vue-virtual": "^3.13.18",
    "accessor-fn": "^1.5.1",
    "axios": "^1.6.5",
    "codemirror": "^6.0.2",
    "d3-array": "^3.2.4",
    "d3-binarytree": "^1.0.2",
    "d3-dispatch": "^3.0.1",
    "d3-octree": "^1.0.2",
    "d3-quadtree": "^3.0.1",
    "d3-scale": "^4.0.2",
    "d3-scale-chromatic": "^3.1.0",
    "d3-timer": "^3.0.1",
    "data-bind-mapper": "^1.0.3",
    "graphology": "^0.25.4",
    "graphology-communities-louvain": "^2.0.2",
    "kapsule": "^1.16.1",
    "lucide-vue-next": "^0.577.0",
    "ngraph.forcelayout": "^3.3.1",
    "ngraph.graph": "^20.0.1",
    "pinia": "^2.1.7",
    "primevue": "^4.5.4",
    "three": "^0.170.0",
    "three-render-objects": "^1.35.2",
    "three-spritetext": "^1.10.0",
    "tinycolor2": "^1.6.0",
    "vue": "^3.4.15",
    "vue-codemirror": "^6.1.1",
    "vue-router": "^4.2.5"
  },
  "devDependencies": {
    "@playwright/test": "^1.45.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/vue": "^8.1.0",
    "@types/node": "^20.11.5",
    "@types/three": "^0.182.0",
    "@typescript-eslint/eslint-plugin": "^8.57.0",
    "@typescript-eslint/parser": "^8.57.0",
    "@vitejs/plugin-vue": "^5.0.3",
    "@vitest/coverage-v8": "^1.6.1",
    "@vitest/ui": "^1.6.1",
    "@vue/tsconfig": "^0.5.1",
    "eslint": "^8.57.1",
    "eslint-plugin-vue": "^10.8.0",
    "happy-dom": "^20.5.0",
    "msdf-bmfont-xml": "^2.8.0",
    "stats-gl": "^4.0.2",
    "typescript": "~5.3.0",
    "vite": "^5.0.11",
    "vitest": "^1.2.1",
    "vue-tsc": "^1.8.27"
  }
}
